# Server Configuration
PORT=3001

# Application Environment
NODE_ENV=development

# LLM / AI Configuration (Used by @guardian/agent)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Search API Configuration
TAVILY_API_KEY=your_tavily_api_key_here

# Similarity Service Configuration (Python sidecar)
SIMILARITY_HOST=127.0.0.1
SIMILARITY_PORT=8100

# Audio Fingerprinting (Chromaprint)
# Requires fpcalc binary on PATH — install via: apt install libchromaprint-tools (Linux) or brew install chromaprint (macOS)
AUDIO_SAMPLE_RATE=16000
AUDIO_SEGMENT_SEC=15

# Matching Thresholds
MATCH_THRESHOLD=0.80
GAP_TOLERANCE_SEC=2

# -------------------------------------------------------------
# Commands to start the API project:
# 1. cd apps/api
# 2. npm install (or run npm install at the monorepo root)
# 3. npm run dev (uses node --watch)
# -------------------------------------------------------------
